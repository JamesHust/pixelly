# PostgreSQL
POSTGRES_USER=pixelly
POSTGRES_PASSWORD=pixelly_secret
POSTGRES_DB=pixelly
DATABASE_URL=postgres://pixelly:pixelly_secret@localhost:5432/pixelly?sslmode=disable

# Redis
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# JWT
JWT_SECRET=change_me_in_production_min_32_chars

# Backend
PORT=8080
CORS_ORIGINS=http://localhost:3000
# AI Provider — "ollama" (local) or "openai" (Groq, OpenRouter, OpenAI, etc.)
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_MODEL=llama3.2
AI_API_KEY=

# --- Groq (free, no credit card) ---
# 1. Đăng ký tại https://console.groq.com → tạo API key
# 2. Uncomment 4 dòng dưới, comment 4 dòng trên
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.1-8b-instant
# AI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXTAUTH_SECRET=change_me_in_production
NEXTAUTH_URL=http://localhost:3000
